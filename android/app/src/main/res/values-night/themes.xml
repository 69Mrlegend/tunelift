<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Keep the same dark theme at night (premium dark always). -->
    <style name="Theme.TuneLift" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/tuneliftBg</item>
        <item name="windowSplashScreenBackground">@color/tuneliftBg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">450</item>
        <item name="postSplashScreenTheme">@style/Theme.TuneLift</item>
    </style>
</resources>

